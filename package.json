{
  "name": "symphony-pi",
  "version": "0.4.1",
  "type": "module",
  "description": "Generic Symphony autonomous issue orchestration extension for pi.",
  "keywords": [
    "pi-package",
    "pi-extension",
    "symphony",
    "automation"
  ],
  "bin": {
    "pi-symphony": "bin/pi-symphony.mjs"
  },
  "files": [
    "bin/",
    "docs/",
    "examples/",
    "scripts/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "build": "echo 'pi loads TypeScript extensions directly; no build required'",
    "cli": "node --import tsx src/cli.ts",
    "smoke:pi-extension": "node scripts/smoke-pi-extension.mjs",
    "smoke:codex-schema": "node scripts/check-codex-schema.mjs",
    "smoke": "npm run smoke:pi-extension && npm run smoke:codex-schema && npm run smoke:codex-app-server && npm run smoke:beads-e2e",
    "smoke:codex-app-server": "node --import tsx scripts/smoke-codex-app-server.ts",
    "smoke:beads-e2e": "node --import tsx scripts/smoke-beads-e2e.ts",
    "smoke:beads-e2e:pi": "PI_SYMPHONY_E2E_RUNNER=pi node --import tsx scripts/smoke-beads-e2e.ts",
    "smoke:linear-live": "node --import tsx scripts/smoke-linear-live.ts",
    "smoke:jira-live": "node --import tsx scripts/smoke-jira-live.ts",
    "smoke:live": "npm run smoke:linear-live && npm run smoke:jira-live",
    "prepublishOnly": "npm run check && npm test && npm run smoke:pi-extension"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@types/node": "^24.0.0",
    "fallow": "^2.62.0",
    "typescript": "^5.9.0"
  },
  "dependencies": {
    "liquidjs": "^10.25.7",
    "tsx": "^4.20.5",
    "yaml": "^2.8.4"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/juhas96/symphony-pi.git"
  },
  "bugs": {
    "url": "https://github.com/juhas96/symphony-pi/issues"
  },
  "homepage": "https://github.com/juhas96/symphony-pi#readme",
  "engines": {
    "node": ">=22"
  }
}
